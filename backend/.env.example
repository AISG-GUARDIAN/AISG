# === JWT 설정 ===
SECRET_KEY=your-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# === Azure Custom Vision (Prediction) ===
AZURE_CUSTOM_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_CUSTOM_KEY=your-prediction-key
AZURE_CUSTOM_VISION_PROJECT_ID=your-project-id
AZURE_CUSTOM_VISION_PUBLISH_NAME=Iteration1

# === Azure Face API ===
AZURE_FACE_API=https://your-resource.cognitiveservices.azure.com
AZURE_FACE_KEY=your-face-key

# === Azure Blob Storage ===
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_BLOB_CONTAINER=safety-images

# === 데이터베이스 ===
DATABASE_URL=sqlite:///./safety_check.db

# === 기본 관리자 ===
DEFAULT_EMP_NO=20260312
DEFAULT_ADMIN_NAME=가디언
