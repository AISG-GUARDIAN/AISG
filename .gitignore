# ==========================================
# Easy Welfare Guide - .gitignore
# ==========================================

# ============ Environment ============
.env
.env.*
!.env.example

# ============ Python ============
# Byte-compiled
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
.venv/
env/
ENV/
backend/venv/
backend/.venv/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Testing
.pytest_cache/
.coverage
htmlcov/
*.cover

# Type checking
.mypy_cache/
.pytype/
.ruff_cache/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# ============ Logs ============
logs/
*.log

# ============ Frontend (React) ============
# Dependencies
node_modules/
frontend/node_modules/

# Production build
frontend/build/
frontend/dist/

# Testing
frontend/coverage/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============ OS ============
.DS_Store
Thumbs.db

# ============ Database ============
*.db
*.sqlite
*.sqlite3

# ============ Temporary ============
tmp/
temp/
*.tmp
*.bak
*.backup

# ============ Project Specific ============
# Azure credentials (if any)
azure-credentials.json

# Uploaded files (if storing locally)
uploads/

# Model cache
.cache/